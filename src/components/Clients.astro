---
import { t } from '../i18n/ui';
---
<section class="logo-cloud-section">
  <div class="container" style="text-align:center; margin-bottom:2rem">
    <div class="logo-cloud-eyebrow" data-i18n="clients.eyebrow">{t('clients.eyebrow')}</div>
    <h2 class="logo-cloud-title" data-i18n="clients.title" set:html={t('clients.title')} />
  </div>

  <div class="logo-cloud-track-wrap">
    <div class="logo-cloud-fade logo-cloud-fade-l"></div>
    <div class="logo-cloud-fade logo-cloud-fade-r"></div>
    <div class="logo-cloud-track" id="logoTrack">
      <div class="logo-cloud-inner">
        <span class="logo-item"><span class="logo-dot"></span>Walmart</span>
        <span class="logo-item"><span class="logo-dot"></span>OXXO</span>
        <span class="logo-item"><span class="logo-dot"></span>Majore</span>
        <span class="logo-item"><span class="logo-dot"></span>San Luis</span>
        <span class="logo-item logo-item--long"><span class="logo-dot"></span>Todo Pal Campo</span>
        <span class="logo-item"><span class="logo-dot"></span>Walmart</span>
        <span class="logo-item"><span class="logo-dot"></span>OXXO</span>
        <span class="logo-item"><span class="logo-dot"></span>Majore</span>
        <span class="logo-item"><span class="logo-dot"></span>San Luis</span>
        <span class="logo-item logo-item--long"><span class="logo-dot"></span>Todo Pal Campo</span>
      </div>
    </div>
  </div>
</section>
