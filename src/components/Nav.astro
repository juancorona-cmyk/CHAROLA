---
import { t } from '../i18n/ui';
---
<nav class="nav" id="nav">

  <a href="#inicio" class="nav-logo">
    <img src="https://res.cloudinary.com/ddtjwooiz/image/upload/v1777391322/charola/logo.svg" alt="Naturizable logo" class="nav-logo-mark" style="object-fit:contain;" />
    Naturizable
  </a>

  <ul class="nav-pill" id="navPill">
    <li class="nav-pill-cursor" id="navCursor" aria-hidden="true"></li>
    <li class="nav-pill-item"><a href="#manifiesto" data-i18n="nav.manifesto">{t('nav.manifesto')}</a></li>
    <li class="nav-pill-item"><a href="#producto" data-i18n="nav.product">{t('nav.product')}</a></li>
    <li class="nav-pill-item"><a href="#embajadores" data-i18n="nav.ambassadors">{t('nav.ambassadors')}</a></li>
    <li class="nav-pill-item"><a href="#casos" data-i18n="nav.cases">{t('nav.cases')}</a></li>
    <li class="nav-pill-item"><a href="#contacto" data-i18n="nav.contact">{t('nav.contact')}</a></li>
  </ul>

  <div class="nav-right">
    <div class="lang-toggle">
      <button class="active" data-lang="es">ES</button>
      <button data-lang="en">EN</button>
    </div>
    <a href="#contacto" class="nav-cta">
      <span data-i18n="nav.join">{t('nav.join')}</span>
      <span class="arr">↗</span>
    </a>
  </div>

  <button class="menu-toggle" id="menuToggle" aria-label="Menú">
    <span></span><span></span><span></span>
  </button>

</nav>

<!-- ── FULL-SCREEN MOBILE OVERLAY (sibling of <nav>, escapes backdrop-filter stacking context) ── -->
<div class="nav-mobile" id="navLinks" role="dialog" aria-modal="true" aria-label="Navegación">

  <!-- Header: logo + close -->
  <div class="mob-hdr">
    <a href="#inicio" class="nav-logo">
      <img src="https://res.cloudinary.com/ddtjwooiz/image/upload/v1777391322/charola/logo.svg" alt="Naturizable" class="nav-logo-mark" style="object-fit:contain;" />
      Naturizable
    </a>
    <button class="mob-close" id="menuClose" aria-label="Cerrar menú">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="mob-links">
    <a href="#manifiesto"  class="mob-link" style="--i:0" data-num="01" data-i18n="nav.manifesto">{t('nav.manifesto')}</a>
    <a href="#producto"    class="mob-link" style="--i:1" data-num="02" data-i18n="nav.product">{t('nav.product')}</a>
    <a href="#embajadores" class="mob-link" style="--i:2" data-num="03" data-i18n="nav.ambassadors">{t('nav.ambassadors')}</a>
    <a href="#casos"       class="mob-link" style="--i:3" data-num="04" data-i18n="nav.cases">{t('nav.cases')}</a>
    <a href="#contacto"    class="mob-link" style="--i:4" data-num="05" data-i18n="nav.contact">{t('nav.contact')}</a>
  </nav>

  <!-- Footer: lang toggle + tagline -->
  <div class="mob-foot">
    <span class="mob-tagline">100% compostable · hecho en México</span>
    <div class="lang-toggle">
      <button data-lang="es">ES</button>
      <button data-lang="en">EN</button>
    </div>
  </div>

</div>
