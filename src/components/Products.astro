---
import { t } from '../i18n/ui';
import { ASSETS } from '../lib/cloudinary';
---
<section class="products" id="producto">
  <div class="container">
    <div class="section-head reveal">
      <h2 class="section-title-big" data-i18n="products.title" set:html={t('products.title')} />
    </div>
    <div class="product-grid">

      <div class="product-card reveal" style="--delay:.05s">
        <div class="product-img" style="padding:0;background:#E8E0CC">
          <img src={ASSETS.producto} alt="Charola 855 - Empaque biodegradable de fibra de celulosa, compostable, 510 piezas por caja, aprobado FDA" style="width:100%;height:100%;object-fit:cover" loading="lazy" decoding="async" />
        </div>
        <div class="product-tag" data-i18n="products.p1tag">{t('products.p1tag')}</div>
        <h3 class="product-name" data-i18n="products.p1name">{t('products.p1name')}</h3>
        <p class="product-desc" data-i18n="products.p1desc">{t('products.p1desc')}</p>
        <div class="product-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
        </div>
      </div>

      <div class="product-card product-card--soon reveal" style="--delay:.15s">
        <div class="soon-overlay"><span class="soon-label">Próximamente</span></div>
        <div class="product-img" style="padding:0;background:#E8E0CC">
          <img src={ASSETS.vaso} alt="Vasos de Celulosa compostables para bebidas frías y calientes, sin PFAS ni plástico" style="width:100%;height:100%;object-fit:cover" loading="lazy" decoding="async" />
        </div>
        <div class="product-tag coming" data-i18n="products.inDev">{t('products.inDev')}</div>
        <h3 class="product-name" data-i18n="products.p2name">{t('products.p2name')}</h3>
        <p class="product-desc" data-i18n="products.p2desc">{t('products.p2desc')}</p>
        <div class="product-arrow product-arrow--disabled">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
        </div>
      </div>

      <div class="product-card product-card--soon reveal" style="--delay:.25s">
        <div class="soon-overlay"><span class="soon-label">Próximamente</span></div>
        <div class="product-img" style="padding:0;background:#E8E0CC">
          <img src={ASSETS.contenedor} alt="Contenedores compostables Take-Away con tapa, resistentes al calor, sin plástico ni PFAS" style="width:100%;height:100%;object-fit:cover" loading="lazy" decoding="async" />
        </div>
        <div class="product-tag coming" data-i18n="products.inDev">{t('products.inDev')}</div>
        <h3 class="product-name" data-i18n="products.p3name">{t('products.p3name')}</h3>
        <p class="product-desc" data-i18n="products.p3desc">{t('products.p3desc')}</p>
        <div class="product-arrow product-arrow--disabled">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
        </div>
      </div>


    </div>
  </div>
</section>
