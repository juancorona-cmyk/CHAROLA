---
import { t } from '../i18n/ui';
const events = [
  { key: 'e1', date: '15 May 2026', loc: 'Ciudad de México' },
  { key: 'e2', date: '8 Jun 2026', loc: 'Monterrey, NL' },
  { key: 'e3', date: '22 Sept 2026', loc: 'San Diego, California' },
  { key: 'e4', date: '14 Oct 2026', loc: 'Estambul, Turquía' },
  { key: 'e5', date: '11 Nov 2026', loc: 'Utrecht, Netherlands' },
];
---
<section class="events" id="eventos">
  <div class="container">
    <div class="section-head reveal" style="display:block">
      <h2 class="section-title-big" data-i18n="events.title" set:html={t('events.title')} />
    </div>
    <div class="events-list">
      {events.map(ev => (
        <div class="event-row reveal">
          <div class="event-date">{ev.date}</div>
          <div class="event-name" data-i18n={`events.${ev.key}`}>{t(`events.${ev.key}`)}</div>
          <div class="event-loc">{ev.loc}</div>
          <div class="event-arr">↗</div>
        </div>
      ))}
    </div>
  </div>
</section>
