          <li><a href="mailto:info@naturizable.com">info@naturizable.com</a></li>
          <li><a href="mailto:ventas@naturizable.com">ventas@naturizable.com</a></li>
          <li><a href="tel:+524433575815">+52 443 357 5815</a></li>
          <li><a href="https://maps.google.com/?q=Belisario+Dominguez+30+Morelia+Michoacan" target="_blank">Belisario Domínguez 30 · Morelia ↗</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div data-i18n="footer.copyright">{t('footer.copyright')}</div>
      <div class="moto" data-i18n="footer.moto">{t('footer.moto')}</div>
    </div>
