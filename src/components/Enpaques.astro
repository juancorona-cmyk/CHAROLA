---
import { t } from '../i18n/ui';
import { ASSETS } from '../lib/cloudinary';
---

<section class="enpaques" id="enpaques">

  <!-- ── PANEL 1: dark sticky intro ── -->
  <div class="enp-panel enp-panel--dark">
    <div class="enp-bg-grid"></div>
    <div class="container">
      <div class="enp-panel-content reveal">
        <div class="eyebrow" style="color:var(--gold);margin-bottom:1.5rem">
          <span class="enp-dot"></span>
          <span data-i18n="enpaques.eyebrow">{t('enpaques.eyebrow')}</span>
        </div>
        <h2 class="enp-headline" data-i18n="enpaques.title" set:html={t('enpaques.title')} />
        <div class="enp-scroll-hint">
          <span class="enp-scroll-dot"></span>
          <span data-i18n="enpaques.hint">{t('enpaques.hint')}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── PANEL 2: video scrub track ── -->
  <div class="enp-scrub-track" id="enpScrubTrack">
    <div class="enp-scrub-sticky">
      <video
        id="enpaqueVideo"
        src={ASSETS.video}
        muted
        playsinline
        preload="auto"
        class="enp-video"
      ></video>
      <div class="enp-overlay">
        <div class="enp-overlay-chips">
          <span class="enp-chip">
            <span class="enp-chip-dot"></span>
            <span data-i18n="enpaques.chip1">{t('enpaques.chip1')}</span>
          </span>
          <span class="enp-chip">
            <span class="enp-chip-dot"></span>
            <span data-i18n="enpaques.chip2">{t('enpaques.chip2')}</span>
          </span>
        </div>
        <div class="enp-overlay-foot">
          <span class="enp-watch-label" data-i18n="enpaques.watchLabel">{t('enpaques.watchLabel')}</span>
          <div class="enp-bar-wrap">
            <div class="enp-bar-fill" id="enpBarFill"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── PANEL 3: cream sticky outro ── -->
  <div class="enp-panel enp-panel--cream">
    <div class="container">
      <div class="enp-panel-content enp-panel-content--center reveal">
        <div class="eyebrow" style="justify-content:center;margin-bottom:1.5rem">
          <span class="enp-dot" style="background:var(--gold)"></span>
          <span data-i18n="enpaques.outroEye">{t('enpaques.outroEye')}</span>
        </div>
        <h2 class="enp-headline enp-headline--dark" data-i18n="enpaques.outroTitle" set:html={t('enpaques.outroTitle')} />
      </div>
    </div>
  </div>

</section>

<script>
(function () {
  const video = document.getElementById('enpaqueVideo') as HTMLVideoElement | null;
  const track = document.getElementById('enpScrubTrack');
  const fill  = document.getElementById('enpBarFill');
  if (!video || !track) return;

  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  // iOS unlock: necesita un gesto previo para poder hacer seek
  let unlocked = false;
  function unlock() {
    if (unlocked) return;
    unlocked = true;
    video!.play().then(() => { video!.pause(); video!.currentTime = 0; }).catch(() => {});
  }
  document.addEventListener('touchstart', unlock, { once: true, passive: true });

  function getViewH(): number {
    return window.visualViewport?.height ?? window.innerHeight;
  }

  function applyProgress(p: number) {
    if (video!.duration && !isNaN(video!.duration)) {
      video!.currentTime = p * video!.duration;
    }
    if (fill) fill.style.transform = `scaleX(${p})`;
  }

  // ── DESKTOP: scroll-scrub con lerp suave ──────────────────────────────
  if (!isMobile) {
    let targetP  = 0;
    let currentP = 0;
    let rafId: number | null = null;

    function getScrollProgress(): number {
      const rect  = track!.getBoundingClientRect();
      const total = Math.max(1, track!.offsetHeight - getViewH());
      return Math.max(0, Math.min(0.999, -rect.top / total));
    }

    function tick() {
      rafId = null;
      currentP += (targetP - currentP) * 0.12;
      const delta = Math.abs(targetP - currentP);
      if (delta < 0.0002) currentP = targetP;
      applyProgress(currentP);
      if (delta > 0.0002) rafId = requestAnimationFrame(tick);
    }

    window.addEventListener('scroll', () => {
      targetP = getScrollProgress();
      if (rafId === null) rafId = requestAnimationFrame(tick);
    }, { passive: true });

    video.addEventListener('loadedmetadata', () => applyProgress(getScrollProgress()));
    window.visualViewport?.addEventListener('resize', () => {
      targetP = getScrollProgress();
      if (rafId === null) rafId = requestAnimationFrame(tick);
    });
    return;
  }

  // ── MÓVIL: control directo por touchmove — sin inercia ───────────────
  // El video solo avanza mientras el dedo toca la pantalla.
  let progress     = 0;
  let touchStartY  = 0;
  let progressAtTouchStart = 0;

  function getTrackTotal(): number {
    return Math.max(1, track!.offsetHeight - getViewH());
  }

  document.addEventListener('touchstart', (e) => {
    touchStartY = e.touches[0].clientY;
    progressAtTouchStart = progress;
  }, { passive: true });

  document.addEventListener('touchmove', (e) => {
    // Solo actúa cuando el track está visible en pantalla
    const rect = track!.getBoundingClientRect();
    if (rect.bottom < 0 || rect.top > getViewH()) return;

    const dy    = touchStartY - e.touches[0].clientY; // positivo = bajar
    const delta = dy / getTrackTotal();
    progress    = Math.max(0, Math.min(0.999, progressAtTouchStart + delta));
    applyProgress(progress);
  }, { passive: true });

  video.addEventListener('loadedmetadata', () => applyProgress(0));
})();
</script>
