---
import { t } from '../i18n/ui';
---
<section class="final-cta" id="cta">
  <div class="container">
    <div class="cta-card reveal-scale">
      <div class="cta-eyebrow" data-i18n="cta.eyebrow">{t('cta.eyebrow')}</div>
      <h2 class="cta-title">
        <span data-i18n="cta.title1">{t('cta.title1')}</span><br />
        <em data-i18n="cta.title2">{t('cta.title2')}</em><br />
        <span data-i18n="cta.title3">{t('cta.title3')}</span>
      </h2>
      <p class="cta-sub" data-i18n="cta.sub">{t('cta.sub')}</p>
      <a href="mailto:ventas@naturizable.com?subject=Quiero%20unirme%20al%20movimiento%20Naturizable" class="btn btn-cta-gold">
        <span data-i18n="cta.btn">{t('cta.btn')}</span>
        <span class="arr">↗</span>
      </a>
    </div>
  </div>
</section>
