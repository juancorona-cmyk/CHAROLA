      <div class="footer-brand">
        <a href="#" class="nav-logo">
          <span class="nav-logo-mark">100</span>
          Naturizable
        </a>
        <p class="footer-tagline" data-i18n="footer.tagline">
          {t('footer.tagline')}
        </p>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.col1">{t('footer.col1')}</h4>
        <ul>
          <li><a href="#producto">Charola 855</a></li>
          <li><a href="#" data-i18n="footer.col1l2">{t('footer.col1l2')}</a></li>
          <li><a href="#" data-i18n="footer.col1l3">{t('footer.col1l3')}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.col2">{t('footer.col2')}</h4>
        <ul>
          <li><a href="#tecnologia" data-i18n="footer.col2l1">{t('footer.col2l1')}</a></li>
