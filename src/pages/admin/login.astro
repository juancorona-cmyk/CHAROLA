---
export const prerender = false;

import { isValidToken, getTokenFromCookies } from '../../lib/adminAuth';

const token = getTokenFromCookies(Astro.request.headers.get('cookie'));
if (await isValidToken(token)) {
  return Astro.redirect('/admin');
}

const LOGO = 'https://res.cloudinary.com/ddtjwooiz/image/upload/v1777391322/charola/logo.svg';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin · Acceso — Naturizable</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href={LOGO} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #F4EEDE;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }
    .palette {
      background: #fff;
      border: 1px solid rgba(10,42,31,.13);
      border-radius: 18px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 12px 40px rgba(10,42,31,.12);
      overflow: hidden;
    }
    /* Header strip */
    .p-header {
      background: #0F3D2E;
      padding: 1.4rem 1.6rem;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .p-header img { width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0; }
    .p-header-text h2 { font-size: 1rem; font-weight: 700; color: #fff; line-height: 1.2; }
    .p-header-text p  { font-size: .75rem; color: rgba(255,255,255,.55); margin-top: 2px; }
    /* Top command bar */
    .p-bar {
      padding: .85rem 1.3rem;
      border-bottom: 1px solid rgba(10,42,31,.1);
      display: flex;
      align-items: center;
      gap: 10px;
      background: #FAFAF7;
    }
    .p-bar svg { color: #7C8A82; flex-shrink: 0; }
    .p-bar span { flex: 1; font-size: .82rem; color: #7C8A82; }
    kbd {
      background: #EAE3CF;
      border: 1px solid rgba(10,42,31,.12);
      border-radius: 5px;
      padding: 2px 8px;
      font-size: .67rem;
      color: #7C8A82;
      font-family: inherit;
      flex-shrink: 0;
    }
    /* Form body */
    .p-body { padding: 1.4rem 1.6rem 1.6rem; }
    label {
      display: block;
      font-size: .67rem;
      font-weight: 700;
      color: #7C8A82;
      text-transform: uppercase;
      letter-spacing: .1em;
      margin-bottom: 5px;
    }
    input[type="text"],
    input[type="password"] {
      width: 100%;
      background: #F4EEDE;
      border: 1px solid rgba(10,42,31,.15);
      border-radius: 9px;
      padding: .72rem 1rem;
      color: #0A2A1F;
      font-size: .92rem;
      outline: none;
      transition: border-color .15s, box-shadow .15s;
      margin-bottom: 1rem;
      font-family: inherit;
    }
    input:focus {
      border-color: #1F5C44;
      box-shadow: 0 0 0 3px rgba(31,92,68,.1);
    }
    button {
      width: 100%;
      padding: .8rem;
      background: #0F3D2E;
      color: #fff;
      border: none;
      border-radius: 9px;
      font-size: .92rem;
      font-weight: 700;
      cursor: pointer;
      transition: background .15s, opacity .15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: inherit;
    }
    button:hover   { background: #1F5C44; }
    button:disabled { opacity: .5; cursor: default; }
    #err {
      margin-top: .9rem;
      padding: .65rem .9rem;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 8px;
      color: #b91c1c;
      font-size: .8rem;
      display: none;
    }
    .hint {
      text-align: center;
      font-size: .7rem;
      color: #B8C9B5;
      margin-top: 1rem;
    }
  </style>
</head>
<body>

<div class="palette">
  <div class="p-header">
    <img src={LOGO} alt="Naturizable" />
    <div class="p-header-text">
      <h2>100% Naturizable</h2>
      <p>Panel de administración</p>
    </div>
  </div>

  <div class="p-bar">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="11" width="18" height="11" rx="2"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>
    <span>Ingresa tus credenciales de acceso</span>
    <kbd>Esc</kbd>
  </div>

  <div class="p-body">
    <form id="loginForm">
      <label for="user">Usuario</label>
      <input type="text" id="user" name="username" autocomplete="username" autofocus placeholder="admin" />
      <label for="pass">Contraseña</label>
      <input type="password" id="pass" name="password" autocomplete="current-password" />
      <button type="submit" id="btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        Entrar al dashboard
      </button>
      <div id="err">Credenciales incorrectas. Inténtalo de nuevo.</div>
    </form>
    <p class="hint">También puedes acceder con <kbd>Ctrl</kbd>+<kbd>K</kbd> desde el sitio</p>
  </div>
</div>

<script>
  const form = document.getElementById('loginForm');
  const btn  = document.getElementById('btn');
  const err  = document.getElementById('err');

  document.addEventListener('keydown', e => { if (e.key === 'Escape') window.history.back(); });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    err.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Verificando…';

    try {
      const res = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          username: document.getElementById('user').value.trim(),
          password: document.getElementById('pass').value,
        }),
      });

      if (res.ok) {
        window.location.href = '/admin';
      } else {
        err.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Entrar al dashboard';
      }
    } catch {
      err.textContent = 'Error de conexión.';
      err.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Entrar al dashboard';
    }
  });
</script>
</body>
</html>
